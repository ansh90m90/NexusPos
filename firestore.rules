// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: shops
// Document ID: shopId (string)
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - ownerEmail: string (required)
//   - masterListId: string (optional)
//   - createdAt: timestamp (required)
//
// Collection: shops/{shopId}/snapshots
// Document ID: snapshotId (string)
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - timestamp: timestamp (required)
//   - categories: list (required)
//   - data: map (required)
//
// Collection: shops/{shopId}/public_menu
// Document ID: current (string)
// Fields:
//   - shopName: string (required)
//   - lastUpdated: timestamp (required)
//   - categories: list (required)
//
// Collection: master_lists
// Document ID: listId (string)
// Fields:
//   - id: string (required)
//   - name: string (required)
//   - ownerEmail: string (required)
//   - products: list (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(email) {
      return isAuthenticated() && request.auth.token.email == email;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "pushpasingh1985a@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidShop(data) {
      return data.keys().hasAll(['id', 'name', 'ownerEmail', 'createdAt']) &&
             data.id is string && data.name is string && data.name.size() > 0 &&
             data.ownerEmail is string && data.createdAt is timestamp;
    }

    function isValidSnapshot(data) {
      return data.keys().hasAll(['id', 'name', 'timestamp', 'data']) &&
             data.id is string && data.name is string && data.name.size() > 0 &&
             data.timestamp is timestamp && data.data is map &&
             (!('categories' in data) || data.categories is list);
    }

    function isValidPublicMenu(data) {
      return data.keys().hasAll(['shopName', 'lastUpdated', 'categories']) &&
             data.shopName is string && data.lastUpdated is timestamp && data.categories is list;
    }

    function isValidMasterList(data) {
      return data.keys().hasAll(['id', 'name', 'ownerEmail', 'products', 'ownerId', 'lastUpdated']) &&
             data.id is string && data.name is string && data.ownerEmail is string && 
             data.products is list && data.ownerId is string && data.lastUpdated is timestamp;
    }

    function isAccountOwner(accountId) {
      return isAuthenticated() && (
        request.auth.uid == accountId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountId == accountId)
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow get, list: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /accounts/{accountId} {
      allow get, list: if isAuthenticated() && (isAccountOwner(accountId) || isAdmin());
      allow create, update: if isAuthenticated() && (isAccountOwner(accountId) || isAdmin());
      allow delete: if isAdmin();
      
      match /businesses/{businessId} {
        allow get, list: if isAuthenticated() && (isAccountOwner(accountId) || isAdmin());
        allow create, update: if isAuthenticated() && (isAccountOwner(accountId) || isAdmin());
        allow delete: if isAdmin();
        
        match /operations/{opId} {
          allow get, list: if isAuthenticated() && (isAccountOwner(accountId) || isAdmin());
          allow create, update: if isAuthenticated() && (isAccountOwner(accountId) || isAdmin());
          allow delete: if isAdmin();
        }
      }
    }

    match /shops/{shopId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.ownerEmail) || isAdmin());
      allow create: if isAuthenticated() && isValidShop(request.resource.data) && (isOwner(request.resource.data.ownerEmail) || isAdmin());
      allow update: if isAuthenticated() && isValidShop(request.resource.data) && (isOwner(resource.data.ownerEmail) || isAdmin());
      allow delete: if isAuthenticated() && (isOwner(resource.data.ownerEmail) || isAdmin());

      match /snapshots/{snapshotId} {
        allow read, write: if isAuthenticated() && (isOwner(get(/databases/$(database)/documents/shops/$(shopId)).data.ownerEmail) || isAdmin());
      }

      match /public_menu/current {
        // Explicit request for unauthenticated read access for customers
        allow read: if true; 
        allow write: if isAuthenticated() && (isOwner(get(/databases/$(database)/documents/shops/$(shopId)).data.ownerEmail) || isAdmin());
      }
    }

    match /master_lists/{listId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidMasterList(request.resource.data);
      allow update: if isAuthenticated() && isValidMasterList(request.resource.data);
      allow delete: if isAuthenticated() && (isOwner(resource.data.ownerEmail) || isAdmin());
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
