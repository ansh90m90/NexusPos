{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account associations",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "accountId": { "type": "string", "description": "The ID of the account this user belongs to" }
      },
      "required": ["id", "name", "email", "accountId"]
    },
    "Account": {
      "title": "Account",
      "description": "A top-level account that can own multiple businesses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Business": {
      "title": "Business",
      "description": "A specific business or shop under an account",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "accountId": { "type": "string" },
        "data": { "type": "object", "description": "The AccountState object" },
        "lastSyncId": { "type": "number" }
      },
      "required": ["id", "name", "accountId", "data"]
    },
    "Operation": {
      "title": "Operation",
      "description": "A single state mutation operation",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "clientId": { "type": "string" },
        "type": { "type": "string" },
        "payload": { "type": "object" },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "clientId", "type", "payload", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Top-level accounts"
    },
    "/accounts/{accountId}/businesses/{businessId}": {
      "schema": "Business",
      "description": "Businesses under an account"
    },
    "/accounts/{accountId}/businesses/{businessId}/operations/{operationId}": {
      "schema": "Operation",
      "description": "Operation log for synchronization"
    }
  }
}
