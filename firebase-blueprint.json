{
  "entities": {
    "Shop": {
      "title": "Shop",
      "description": "Main shop configuration and metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "masterListId": { "type": "string", "description": "ID of the master inventory list this shop is linked to" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerEmail"]
    },
    "Snapshot": {
      "title": "Cloud Snapshot",
      "description": "A customizable backup of shop data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "data": { "type": "object", "description": "The actual JSON data of the snapshot" }
      },
      "required": ["id", "name", "timestamp", "data"]
    },
    "MasterList": {
      "title": "Master Inventory List",
      "description": "A shared list of products for multi-store synchronization",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerEmail": { "type": "string" },
        "products": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "ownerEmail"]
    },
    "PublicMenu": {
      "title": "Public Live Menu",
      "description": "Read-only data for customers to view current stock and prices",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "categories": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "items": { "type": "array", "items": { "type": "object" } }
            }
          } 
        }
      }
    },
    "User": {
      "title": "User Profile",
      "description": "User account information and linked businesses",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "accounts": { "type": "array", "items": { "type": "object" } }
      }
    },
    "Account": {
      "title": "Account",
      "description": "A container for multiple businesses",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" }
      }
    },
    "Business": {
      "title": "Business State",
      "description": "The full state of a business",
      "type": "object",
      "properties": {
        "data": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Operation": {
      "title": "Sync Operation",
      "description": "A single change to the business state",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "type": { "type": "string" },
        "payload": { "type": "object" },
        "timestamp": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Account containers"
    },
    "/accounts/{accountId}/businesses/{businessId}": {
      "schema": "Business",
      "description": "Business state snapshots"
    },
    "/accounts/{accountId}/businesses/{businessId}/operations/{opId}": {
      "schema": "Operation",
      "description": "Incremental sync operations"
    },
    "/shops/{shopId}": {
      "schema": "Shop",
      "description": "Shop metadata"
    },
    "/shops/{shopId}/snapshots/{snapshotId}": {
      "schema": "Snapshot",
      "description": "Customizable cloud backups"
    },
    "/shops/{shopId}/public_menu/current": {
      "schema": "PublicMenu",
      "description": "Live menu data for customers"
    },
    "/master_lists/{listId}": {
      "schema": "MasterList",
      "description": "Shared inventory for multi-store sync"
    }
  }
}
